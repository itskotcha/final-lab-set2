# Database Credentials (อ้างอิงจาก docker-compose)
POSTGRES_USER=admin
POSTGRES_PASSWORD=secret

# Database Names
AUTH_DB_NAME=authdb
TASK_DB_NAME=taskdb
USER_DB_NAME=userdb

# JWT Configuration (ต้องตรงกับที่ระบุใน docker-compose เพื่อแก้ 401)
JWT_SECRET=dev-shared-secret
JWT_EXPIRES=1h

# Service Ports
AUTH_PORT=3001
TASK_PORT=3002
USER_PORT=3003
FRONTEND_PORT=8080